# ─────────────────────────────────────────────────────────────────────────────
#  Semantic Cache Proxy — Environment Configuration
#  1. Copy this file:  cp .env.example .env
#  2. Fill in the values below
#  3. Run:            docker-compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Postgres + pgvector) ───────────────────────────────────────────
# Change the password. The username and database name can stay as-is.
POSTGRES_USER=cache
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=cache

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used as the L2a (exact-match) cache layer. No password required for local use,
# but set one for any public-facing deployment.
REDIS_PASSWORD=

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a random 64-character string before going public.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── Embeddings ────────────────────────────────────────────────────────────────
# The embedding model used for semantic (meaning-based) cache lookups.
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama   # "ollama" or "openai"

# Only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# ── Cache Tuning ──────────────────────────────────────────────────────────────
L1_MAX_BYTES=134217728     # L1 in-memory cache size (default: 128MB)
L1_DEFAULT_TTL=3600        # L1 TTL in seconds (default: 1 hour)

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=1000        # Requests per minute per tenant

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CB_MAX_FAILURES=5          # Failures before opening the circuit
CB_TIMEOUT=30s             # How long to wait before retrying

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info             # "debug", "info", "warn", "error"

# ── Grafana (optional) ────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
